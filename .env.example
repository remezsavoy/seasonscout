# Frontend (Vite)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Shared admin script secret
# Used by:
# - scripts/seed-canary.mjs
# - scripts/enrich-canary.mjs
# - supabase/functions/ingest-destination-batch
# - supabase/functions/import-destination-climate
# - supabase/functions/enrich-destination
# - supabase/functions/enrich-country
# - supabase/functions/compose-country-editorial
SEASONSCOUT_INGESTION_SECRET=your_ingestion_secret

# AI and media enrichment (Supabase Edge Functions)
# Used by:
# - supabase/functions/compose-country-editorial
# - supabase/functions/extract-country-tourism
GEMINI_API_KEY=your_gemini_api_key

# Optional model overrides for Gemini-backed functions
SEASONSCOUT_GEMINI_COUNTRY_EDITORIAL_MODEL=gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# Used by:
# - supabase/functions/enrich-destination
# - supabase/functions/enrich-country
# - supabase/functions/compose-country-editorial
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Recommended for Wikimedia requests made by:
# - supabase/functions/enrich-destination
# - supabase/functions/enrich-country
SEASONSCOUT_WIKIMEDIA_USER_AGENT=SeasonScout/1.0 (your-contact-info)

# Edge Function runtime
# Supabase injects these automatically in deployed functions.
# Only set them manually when running functions outside the managed runtime.
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
